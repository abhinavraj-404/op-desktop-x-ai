# API keys — one per model role.
# Models, endpoints, and all other settings live in config/default.toml.
#
# Use separate keys if your planner and executor are on different providers,
# or set the same key for both if they share an account.

PLANNER_API_KEY=your_planner_api_key_here
EXECUTOR_API_KEY=your_executor_api_key_here

# OpenAI fallback — used for whichever key above is left unset:
# OPENAI_API_KEY=your_openai_api_key_here
